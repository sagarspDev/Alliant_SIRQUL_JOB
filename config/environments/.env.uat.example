FLEET_API_BASE_URL=https://fleetshare.bmrang.com:3003
FLEET_API_APP_KEY=uat-app-key
FLEET_API_AUTH_TOKEN=uat-bearer-token
FLEET_NETWORK_UID=uat-network-uid

REPORTING_API_BASE_URL=https://fleetshare.bmrang.com
REPORTING_API_APP_KEY=uat-reporting-app-key
REPORTING_API_REST_KEY=uat-reporting-rest-key
REPORTING_ACCOUNT_ID=

TARGET_RETAILER_LOCATION_ID=
DATE_RANGE_START=
DATE_RANGE_END=

DAILY_WINDOW_MODE=utc_day
DAILY_WINDOW_HOURS=
DAILY_MAX_FLEETS=
DAILY_FAIL_POLICY=continue
DAILY_SKIP_DISCOVERY=false

OUTPUT_DIR=/opt/fleetlytics/var/output/uat
LOG_DIR=/var/log/fleetlytics/uat
LOG_LEVEL=INFO
CRON_LOCK_PATH=/opt/fleetlytics/var/state/uat/daily.lock
CRON_HEALTH_PATH=/opt/fleetlytics/var/state/uat/daily_health.json
CRON_LOG_RETENTION_DAYS=14
RUN_LOG_MAX_BYTES=5242880
RUN_LOG_BACKUP_COUNT=5

HTTP_TIMEOUT_SECONDS=30
HTTP_RETRY_COUNT=3
HTTP_BACKOFF_FACTOR=0.5

SUPABASE_DB_URL=postgresql://uat_user:uat_password@uat-db-host:5432/uat_database
SUPABASE_SCHEMA=public

SCORE_SNAPSHOT_DATE_MODE=end_date
SCORE_SNAPSHOT_DATE_CUSTOM=
