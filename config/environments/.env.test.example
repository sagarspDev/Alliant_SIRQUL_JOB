FLEET_API_BASE_URL=https://fleetshare.bmrang.com:3003
FLEET_API_APP_KEY=test-app-key
FLEET_API_AUTH_TOKEN=test-bearer-token
FLEET_NETWORK_UID=test-network-uid

REPORTING_API_BASE_URL=https://fleetshare.bmrang.com
REPORTING_API_APP_KEY=test-reporting-app-key
REPORTING_API_REST_KEY=test-reporting-rest-key
REPORTING_ACCOUNT_ID=

TARGET_RETAILER_LOCATION_ID=
DATE_RANGE_START=
DATE_RANGE_END=

DAILY_WINDOW_MODE=rolling_hours
DAILY_WINDOW_HOURS=1
DAILY_MAX_FLEETS=5
DAILY_FAIL_POLICY=continue
DAILY_SKIP_DISCOVERY=true

OUTPUT_DIR=/opt/fleetlytics/var/output/test
LOG_DIR=/var/log/fleetlytics/test
LOG_LEVEL=DEBUG
CRON_LOCK_PATH=/opt/fleetlytics/var/state/test/daily.lock
CRON_HEALTH_PATH=/opt/fleetlytics/var/state/test/daily_health.json
CRON_LOG_RETENTION_DAYS=7
RUN_LOG_MAX_BYTES=5242880
RUN_LOG_BACKUP_COUNT=3

HTTP_TIMEOUT_SECONDS=20
HTTP_RETRY_COUNT=2
HTTP_BACKOFF_FACTOR=0.3

SUPABASE_DB_URL=postgresql://test_user:test_password@test-db-host:5432/test_database
SUPABASE_SCHEMA=public

TARGET_COMPANY_ID=00000000-0000-0000-0000-000000000000
SCORE_SNAPSHOT_DATE_MODE=end_date
SCORE_SNAPSHOT_DATE_CUSTOM=
